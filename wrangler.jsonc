{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kolonia",
  "compatibility_date": "2026-05-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.ts",
  // Utwórz bazę: npx wrangler d1 create kolonia-db
  // Wklej prawdziwe database_id z outputu (Dashboard → D1 → kolonia-db też działa).
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kolonia-db",
      "database_id": "113bfdc9-a00e-4943-9a62-42373a81973e"
    }
  ]
}
