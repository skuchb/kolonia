# Google OAuth (production + local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Token signing (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET=

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Launch day is fixed in src/core/daily.ts (LAUNCH_DAY=2026-06-15)

# Admin access: comma-separated Google subject IDs (from OAuth tokeninfo `sub`)
ADMIN_GOOGLE_SUBS=

# Optional — telemetry privacy + analytics
IP_HASH_SALT=
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Google redirect URI (per environment):
#   http://localhost:3000/api/auth/google/callback
#   https://your-domain/api/auth/google/callback
